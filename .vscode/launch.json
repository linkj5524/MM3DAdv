{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: digit",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "args": [
                "--attack_config_path",
                "models/attack_config.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: physial attack ",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "args": [
                "--attack_config_path",
                "models/attack_config_physical_attack.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}